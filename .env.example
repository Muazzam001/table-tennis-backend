# Server (Express API)
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL / Supabase
# Local dev: session pooler (5432) or direct URL is fine
# Vercel/production: use transaction pooler (6543) — see DATABASE_URL_POOLER below
SUPABASE_DB_PASSWORD=[YOUR-PASSWORD]
SUPABASE_PROJECT_REF=zhbyslleexcktjpcdjxq
SUPABASE_POOLER_HOST=aws-1-ap-northeast-1.pooler.supabase.com

# Preferred for Vercel serverless (transaction mode, port 6543)
# DATABASE_URL_POOLER=postgresql://postgres.[REF]:[PASSWORD]@[POOLER_HOST]:6543/postgres?pgbouncer=true

# Optional override for direct connection (IPv6-only on Supabase; prefer pooler on IPv4)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Optional: override pg pool size (default 1 on Vercel, 10 locally)
# PG_POOL_MAX=1

# MySQL source (Phase 2 data migration — optional after cutover)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=table_tennis_tournament
# DB_PORT=3306

# Supabase API keys (backend — service/secret key only, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-or-secret-key

# JWT (custom auth — Phase 1)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Admin bootstrap (npm run create-admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
