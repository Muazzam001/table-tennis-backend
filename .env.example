# Server (Express API)
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# PostgreSQL / Supabase — direct host is IPv6-only; use session pooler on IPv4 networks
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.zhbyslleexcktjpcdjxq.supabase.co:5432/postgres
SUPABASE_DB_PASSWORD=[YOUR-PASSWORD]
SUPABASE_PROJECT_REF=zhbyslleexcktjpcdjxq
SUPABASE_POOLER_HOST=aws-1-ap-northeast-1.pooler.supabase.com

# MySQL source (Phase 2 data migration — optional after cutover)
# DB_HOST=localhost
# DB_USER=root
# DB_PASS=
# DB_NAME=table_tennis_tournament
# DB_PORT=3306

# Supabase API keys (backend — service/secret key only, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-service-role-or-secret-key

# JWT (custom auth — Phase 1)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Admin bootstrap (npm run create-admin)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
