{
  "version": 2,
  "builds": [
    {
      "src": "vercel-entry.mjs",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["shared/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "vercel-entry.mjs"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "NODE_OPTIONS": "--import ./register-aliases.js"
  }
}

